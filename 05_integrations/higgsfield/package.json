{
  "name": "@cao/integration-higgsfield",
  "version": "0.0.0",
  "private": true,
  "description": "Adapter para Higgsfield Skills + CLI (descobrir, instalar, executar skills)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@cao/shared-types": "workspace:*"
  }
}
