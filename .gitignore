node_modules/
.pnpm-store/

# Build output
dist/
build/
out/
.next/
.turbo/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Env
.env
.env.local
.env.*.local

# OS / Editor
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# Obsidian — cada operador configura o próprio vault. Config recomendada
# vive em .obsidian.template/ (versionada como referência).
.obsidian/

# Caveman skills (npx skills add fallback dumps aqui quando claude CLI
# não está no PATH). Per-repo install local; não versionar.
.agents/
skills-lock.json

# Coverage / cache
coverage/
.cache/
*.tsbuildinfo

# Upstreams — read-only (ADR-0002). Cada operador clona localmente via
# `bash 10_ops/scripts/clone-upstreams.sh`. Conteúdo NÃO entra no monorepo
# para manter o repo leve. Manifest de versões pinned vive no script.
01_upstreams/*/
!01_upstreams/README.md

# Memory vault — tenants (por loja Shopify) são local-only. Apenas o
# template e o cérebro operacional (projects/) ficam versionados.
07_memory/vault/*/
!07_memory/vault/_template/
!07_memory/vault/projects/

.obsidian/
12_reports/team-onboarding.html
12_reports/team-onboarding.pdf
**/node_modules/
**/dist/
**/*.tsbuildinfo
