# feed-service — variáveis de ambiente esperadas.

# === LLM provider (a confirmar default — Anthropic ou Gemini) ===
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# === Worker queue (mesmo redis do merchant-service em dev) ===
REDIS_URL=redis://localhost:6379

# === Provider reads ===
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_MERCHANT_ACCOUNT_ID=

# === Telemetria ===
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# === HTTP (apenas health endpoint) ===
PORT=8082
NODE_ENV=development
