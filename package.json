{
  "name": "commerce-agent-os",
  "version": "0.0.0",
  "private": true,
  "description": "Sistema operacional de agentes para e-commerce",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r --filter \"./06_packages/*\" run build",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:smoke": "vitest run 11_tests/smoke",
    "audit:repo": "tsx 03_agents/repo-auditor/src/cli.ts",
    "synthesize:audit": "tsx --env-file-if-exists=.env.local 03_agents/audit-synthesizer/src/cli.ts",
    "curate:memory": "tsx --env-file-if-exists=.env.local 03_agents/learning-memory-curation/src/cli.ts",
    "context:brief": "tsx --env-file-if-exists=.env.local 03_agents/memory-context/src/cli.ts",
    "llm:smoke": "tsx --env-file-if-exists=.env.local 06_packages/llm/scripts/smoke.ts",
    "shopify:list-products": "tsx --env-file-if-exists=.env.local 04_apps/shopify-admin-app/scripts/list-products.ts",
    "shopify:writeback": "tsx --env-file-if-exists=.env.local 04_apps/shopify-admin-app/scripts/writeback.ts",
    "feed:dry-run": "tsx --env-file-if-exists=.env.local 03_agents/catalog-feed-ops/src/cli.ts",
    "merchant:audit": "tsx 03_agents/catalog-feed-ops/src/audit-cli.ts",
    "orchestrate:master": "tsx --env-file-if-exists=.env.local 03_agents/orchestrator-master/src/cli.ts",
    "chief": "tsx --env-file-if-exists=.env.local 06_packages/orchestration/scripts/chief-cli.ts",
    "market:intelligence": "tsx --env-file-if-exists=.env.local 03_agents/market-intelligence/src/cli.ts",
    "competitor:benchmark": "tsx --env-file-if-exists=.env.local 03_agents/competitor-benchmark/src/cli.ts",
    "reviews:ops": "tsx --env-file-if-exists=.env.local 03_agents/reviews-ops/src/cli.ts",
    "product:offer": "tsx --env-file-if-exists=.env.local 03_agents/product-offer/src/cli.ts",
    "merchant:compliance": "tsx --env-file-if-exists=.env.local 03_agents/merchant-compliance/src/cli.ts",
    "governance:qa": "tsx --env-file-if-exists=.env.local 03_agents/governance-risk-qa/src/cli.ts",
    "visual:asset": "tsx --env-file-if-exists=.env.local 03_agents/visual-asset-ops/src/cli.ts",
    "journey:map": "tsx --env-file-if-exists=.env.local 03_agents/customer-journey-ops/src/cli.ts",
    "ads:plan": "tsx --env-file-if-exists=.env.local 03_agents/ads-launchpad/src/cli.ts",
    "finance:radar": "tsx --env-file-if-exists=.env.local 03_agents/finance-margin-radar/src/cli.ts",
    "marketing:plan": "tsx --env-file-if-exists=.env.local 03_agents/marketing-director/src/cli.ts",
    "creative:assets": "tsx --env-file-if-exists=.env.local 03_agents/creative-copy-assets/src/cli.ts",
    "design:ux": "tsx --env-file-if-exists=.env.local 03_agents/design-ux-localization/src/cli.ts",
    "traffic:plan": "tsx --env-file-if-exists=.env.local 03_agents/traffic-campaigns/src/cli.ts",
    "ops:capture": "tsx 06_packages/brain-bridge/scripts/capture-cli.ts",
    "doctor": "tsx 10_ops/scripts/doctor.ts",
    "secret-scan": "gitleaks protect --staged --no-banner --redact",
    "secret-scan:full": "gitleaks detect --no-banner --redact",
    "lint": "biome check .",
    "format": "biome format --write .",
    "commitlint": "commitlint --from=origin/main || true",
    "clean": "pnpm -r exec rm -rf dist .tsbuildinfo"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "typescript": "^5",
    "tsx": "^4",
    "@types/node": "^20",
    "vitest": "^2",
    "@biomejs/biome": "^1.9",
    "simple-git-hooks": "^2",
    "@commitlint/cli": "^19",
    "@commitlint/config-conventional": "^19"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint && pnpm test:smoke && pnpm secret-scan",
    "commit-msg": "pnpm commitlint"
  }
}
