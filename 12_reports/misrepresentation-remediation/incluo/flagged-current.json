003c/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eAutocorreГѓВ§ГѓВЈo:\u003c/strong\u003e O design permite que a crianГѓВ§a identifique e corrija erros de forma autГѓВґnoma, sem dependГѓВЄncia do adulto\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp\u003e\u003cimg src=\"https://cdn.shopify.com/s/files/1/0708/4123/7666/files/livro-de-fracoes-magnetico-montessori-em-madeira-aprendizado-tatil-989.webp?v=1778267359\" alt=\"Livro de fraГѓВ§ГѓВµes magnГѓВ©tico Montessori em madeira - visГѓВЈo geral com peГѓВ§as magnГѓВ©ticas coloridas\" data-original=\"https://cdn.shopify.com/s/files/1/0708/4123/7666/files/Whisk_45fd4bc721d4d47a74a4d0cdd2cf14efdr.png?v=1773263245\"\u003e\u003c/p\u003e\n\u003ch3\u003eConceitos MatemГѓВЎticos Abordados\u003c/h3\u003e\n\u003cul\u003e\n\u003cli\u003eFraГѓВ§ГѓВµes bГѓВЎsicas: 1/2, 1/3, 1/4, 1/5 e mais\u003c/li\u003e\n\u003cli\u003eComparaГѓВ§ГѓВЈo e equivalГѓВЄncia de fraГѓВ§ГѓВµes\u003c/li\u003e\n\u003cli\u003eAdiГѓВ§ГѓВЈo e subtraГѓВ§ГѓВЈo de fraГѓВ§ГѓВµes\u003c/li\u003e\n\u003cli\u003eRelaГѓВ§ГѓВµes entre partes e todo\u003c/li\u003e\n\u003cli\u003eProporГѓВ§ГѓВµes e reconhecimento visual de quantidades fracionГѓВЎrias\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch3\u003eEspecificaГѓВ§ГѓВµes TГѓВ©cnicas\u003c/h3\u003e\n\u003cul\u003e\n\u003cli\u003e\n\u003cstrong\u003eMaterial:\u003c/strong\u003e Madeira natural de alta qualidade\u003c/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eAcabamento:\u003c/strong\u003e Pintura atГѓВіxica e segura\u003c/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eSistema magnГѓВ©tico:\u003c/strong\u003e PeГѓВ§as com ГѓВ­mГѓВЈs embutidos para aderГѓВЄncia segura\u003c/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eDimensГѓВµes:\u003c/strong\u003e 22 cm ГѓвЂ” 18 cm ГѓвЂ” 1,5 cm (formato de livro portГѓВЎtil)\u003c/li\u003e\n\u003cli\u003e\n\u003cstrong\u003ePeso:\u003c/strong\u003e 455 gramas\u003c/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eCores:\u003c/strong\u003e MГѓВєltiplas cores vibrantes para diferenciaГѓВ§ГѓВЈo visual\u003c/li\