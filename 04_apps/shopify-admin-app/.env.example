# shopify-admin-app — variáveis de ambiente esperadas.
# Copiar para .env (que NÃO vai para o git).
# Nomes canônicos vêm de @cao/shared-config SECRET_NAMES.

# === Shopify Partners ===
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_products,write_products,read_orders,read_customers,read_inventory,read_themes,write_themes
SHOPIFY_APP_URL=https://your-tunnel.trycloudflare.com

# === Banco (dev usa SQLite por padrão) ===
DATABASE_URL=file:./prisma/dev.sqlite

# === PostHog ===
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# === LLM (a depender do que o orchestrator chamar) ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# === Ambiente ===
NODE_ENV=development
