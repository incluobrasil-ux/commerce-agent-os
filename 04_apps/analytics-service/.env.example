# analytics-service — variáveis de ambiente esperadas.

# === PostHog ===
# Server-side: personal API key (para HogQL queries via API).
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PROJECT_ID=

# === Worker queue / cron ===
REDIS_URL=redis://localhost:6379

# === LLM (para summarize) ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# === HTTP ===
PORT=8085
NODE_ENV=development
