# creative-ops-service — variáveis de ambiente esperadas.

# === Worker queue ===
REDIS_URL=redis://localhost:6379

# === LLM (para copy + prompts de imagem) ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# === Provedores de mídia (a confirmar; placeholders) ===
MEDIA_IMAGE_PROVIDER_API_KEY=
MEDIA_VIDEO_PROVIDER_API_KEY=

# === Object storage (escolher uma) ===
# AWS S3:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1
# Cloudflare R2:
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_ACCOUNT_ID=
# Google Cloud Storage:
# GCS_BUCKET=
# GCS_PROJECT_ID=

# === CDN (URL base pública) ===
CDN_BASE_URL=https://cdn.cao-creative.local

# === Telemetria ===
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# === HTTP ===
PORT=8084
NODE_ENV=development
