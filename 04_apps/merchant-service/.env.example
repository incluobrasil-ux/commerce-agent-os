# merchant-service — variáveis de ambiente esperadas.
# Copiar para .env (NÃO vai para git).

# === Google Merchant Center ===
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_MERCHANT_ACCOUNT_ID=
GOOGLE_OAUTH_REFRESH_TOKEN=          # se usar OAuth user flow
# OU
# GOOGLE_APPLICATION_CREDENTIALS=     # path para JSON da service account

# === Worker queue (a confirmar) ===
REDIS_URL=redis://localhost:6379

# === Telemetria ===
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# === HTTP ===
PORT=8081
NODE_ENV=development
