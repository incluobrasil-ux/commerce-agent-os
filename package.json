{
  "name": "commerce-agent-os",
  "version": "0.0.0",
  "private": true,
  "description": "Sistema operacional de agentes para e-commerce",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r --filter \"./06_packages/*\" run build",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:smoke": "vitest run 11_tests/smoke",
    "lint": "biome check .",
    "format": "biome format --write .",
    "commitlint": "commitlint --from=origin/main || true",
    "clean": "pnpm -r exec rm -rf dist .tsbuildinfo"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5",
    "tsx": "^4",
    "@types/node": "^20",
    "vitest": "^2",
    "@biomejs/biome": "^1.9",
    "simple-git-hooks": "^2",
    "@commitlint/cli": "^19",
    "@commitlint/config-conventional": "^19"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint && pnpm test:smoke",
    "commit-msg": "pnpm commitlint"
  }
}
