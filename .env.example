# commerce-agent-os — variáveis de ambiente
#
# Como usar:
#   cp .env.example .env.local
#   preencher apenas o que for usar
#
# Regras:
# - .env.local é gitignored (cobre .env*) — nunca commitar valores reais.
# - Nada aqui é obrigatório para `pnpm install / typecheck / lint / test:smoke`.
# - Necessário só quando ativar agentes reais ou integrações externas.
# - Nomes canônicos vêm de `06_packages/shared-config/src/index.ts` (`SECRET_NAMES`).

# ─── LLM ──────────────────────────────────────────────────────────────────────
# Obrigatório para invocar agentes reais via `@cao/runtime`.
# Console: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Opcionais (segundo provedor — sem uso atual no runtime).
OPENAI_API_KEY=
GEMINI_API_KEY=

# ─── Shopify ──────────────────────────────────────────────────────────────────
#
# CAMINHO 1 — Custom App em dev store (mais curto, usado por `pnpm shopify:list-products`).
# Como obter:
#   1. Admin do dev store → Settings → Apps and sales channels → Develop apps
#   2. Create an app → API credentials → Configure Admin API scopes
#      → marcar `read_products` (+ outros conforme necessário) → Save
#   3. Install app → Reveal token once → copiar abaixo
#
# Multi-store: hoje suportamos 1 loja por processo. Para operar múltiplas lojas,
# rode múltiplos processos com `.env.local` distintos OU passe `--shop-domain=...`
# (quando o comando aceitar). Use `--store=<id>` nos comandos para isolar memória
# e reports por loja — convenção: storeId = slug do shopDomain (ex.: `acme`).
SHOPIFY_SHOP=                  # ex.: acme.myshopify.com (sem https://, sem barra)
SHOPIFY_ADMIN_TOKEN=           # ex.: shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# CAMINHO 2 — Public App via OAuth (Fases 2.6+ produção, ainda não usado por scripts).
# Criar em Partners: https://partners.shopify.com/
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_products,write_products,read_orders

# ─── Google Merchant Center ───────────────────────────────────────────────────
# Necessário a partir da Fase 9 (merchant feed).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_MERCHANT_ACCOUNT_ID=

# ─── PostHog (analytics) ──────────────────────────────────────────────────────
# Necessário a partir da Fase 10. Default: cloud EU (ver ADR-0013 quando aceito).
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com

# ─── Higgsfield (creative) ────────────────────────────────────────────────────
# Necessário a partir da Fase 11 (creative em escala).
HIGGSFIELD_API_KEY=

# ─── Bright Data (scraping) ───────────────────────────────────────────────────
# Opcional, uso pontual em competitor-benchmark.
BRIGHTDATA_API_KEY=
