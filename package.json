{
  "name": "commerce-agent-os",
  "version": "0.0.0",
  "private": true,
  "description": "Sistema operacional de agentes para e-commerce",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r --filter \"./06_packages/*\" run build",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:smoke": "vitest run 11_tests/smoke",
    "audit:repo": "tsx 03_agents/repo-auditor/src/cli.ts",
    "synthesize:audit": "tsx --env-file=.env.local 03_agents/audit-synthesizer/src/cli.ts",
    "curate:memory": "tsx --env-file=.env.local 03_agents/learning-memory-curation/src/cli.ts",
    "context:brief": "tsx --env-file=.env.local 03_agents/memory-context/src/cli.ts",
    "llm:smoke": "tsx --env-file=.env.local 06_packages/llm/scripts/smoke.ts",
    "shopify:list-products": "tsx --env-file=.env.local 04_apps/shopify-admin-app/scripts/list-products.ts",
    "feed:dry-run": "tsx --env-file=.env.local 03_agents/catalog-feed-ops/src/cli.ts",
    "secret-scan": "gitleaks protect --staged --no-banner --redact",
    "secret-scan:full": "gitleaks detect --no-banner --redact",
    "lint": "biome check .",
    "format": "biome format --write .",
    "commitlint": "commitlint --from=origin/main || true",
    "clean": "pnpm -r exec rm -rf dist .tsbuildinfo"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5",
    "tsx": "^4",
    "@types/node": "^20",
    "vitest": "^2",
    "@biomejs/biome": "^1.9",
    "simple-git-hooks": "^2",
    "@commitlint/cli": "^19",
    "@commitlint/config-conventional": "^19"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint && pnpm test:smoke && pnpm secret-scan",
    "commit-msg": "pnpm commitlint"
  }
}
