# review-service — variáveis de ambiente esperadas.

# === Worker queue ===
REDIS_URL=redis://localhost:6379

# === LLM (para VoC + drafts) ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# === Telemetria ===
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# === Shopify (para escrever metafields de AggregateRating) ===
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# === Provider tokens — por provider; armazenamento real em secret manager por tenant ===
# Estes aqui são apenas para dev. Em produção, lê do tenant config.
JUDGE_ME_API_TOKEN=
YOTPO_APP_KEY=
YOTPO_API_SECRET=
LOOX_API_KEY=
STAMPED_API_KEY=
OKENDO_API_KEY=

# === HTTP ===
PORT=8083
NODE_ENV=development
