{
  "name": "@cao/memory-context",
  "version": "0.0.0",
  "private": true,
  "description": "Agente read-only que monta context brief de um tenant a partir de facts/, working/ e audit/ recente.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "memory-context": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@cao/core": "workspace:*",
    "@cao/llm": "workspace:*",
    "@cao/memory": "workspace:*",
    "@cao/observability": "workspace:*",
    "@cao/runtime": "workspace:*",
    "zod": "^3"
  }
}
